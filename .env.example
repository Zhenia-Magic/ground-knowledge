# Copy to .env and fill in. Loaded automatically by cli.py, the local UI, and the portal.
# Real shell env vars always take precedence over these.

# LLM key — only needed for AUTOMATIC labelling (discovery + fetch work with no key).
# The two phases pick a provider independently:
#   * SEARCH / discovery uses Anthropic first (needs its web search / deep research), any other
#     key as a no-live-web fallback.
#   * LABELLING uses the first non-Anthropic key — NVIDIA leads and is free, so it labels by
#     default even when an Anthropic key is set for search.
# So set BOTH ANTHROPIC_API_KEY and NVIDIA_API_KEY to get Claude search + free NVIDIA labelling.
ANTHROPIC_API_KEY=
# NVIDIA_API_KEY=      # free, rate-limited (~40 req/min) — build.nvidia.com
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# Optional: pin each phase to one PROVIDER by id (anthropic, nvidia, openai, deepseek, mistral,
# groq, gemini, openrouter) — overrides the automatic split above. A pin whose key isn't set is
# ignored (auto-fallback). The local console's "Models & access" panel sets these live per session.
# EPISTEMIC_SEARCH_PROVIDER=
# EPISTEMIC_LABEL_PROVIDER=

# Optional: pin the model. EPISTEMIC_SEARCH_MODEL / EPISTEMIC_LABEL_MODEL set each phase
# independently; EPISTEMIC_MODEL is a global default applied to both only when they share a
# provider. Examples — Anthropic: claude-sonnet-5, claude-opus-4-8; OpenAI: gpt-4o;
# DeepSeek: deepseek-chat, deepseek-reasoner; Mistral: mistral-large-latest; Gemini:
# gemini-2.0-flash; build.nvidia.com (free): z-ai/glm-5.2 (default), deepseek-ai/deepseek-v4-pro,
# deepseek-ai/deepseek-v4-flash, minimaxai/minimax-m3, nvidia/nemotron-3-ultra-550b-a55b.
# EPISTEMIC_MODEL=
# EPISTEMIC_SEARCH_MODEL=
# EPISTEMIC_LABEL_MODEL=

# Optional: MULTI-MODEL LABELLING ENSEMBLE. List 2+ label models (comma-separated) to run each on
# the label provider and combine field-by-field by majority vote (position ties fall to the
# highest-confidence model and are flagged) — a less model-dependent label. All must be valid ids
# for the label provider (NVIDIA by default). Overrides EPISTEMIC_LABEL_MODEL when set.
# EPISTEMIC_LABEL_MODELS=z-ai/glm-5.2,openai/gpt-oss-120b,mistralai/mistral-nemotron

# Requests/minute ceiling for the rate-limited free provider (NVIDIA build.nvidia.com ~= 40/min).
# The ensemble fans out N calls per batch, so this paces a long run under the limit. 0 disables.
# EPISTEMIC_RATE_LIMIT_RPM=40

# Ingestion tuning (defaults are usually fine).
# EPISTEMIC_HTTP_TIMEOUT=300     # per-request read timeout (s); timeouts are retried, not fatal
# EPISTEMIC_BATCH_CHARS=90000    # max source chars per labelling call (per-call latency, not context)
# EPISTEMIC_BATCH_MAX=4          # max sources per labelling call (output-token safety)
# EPISTEMIC_MAX_SOURCE_CHARS=1000000  # pathological-safety ceiling on one source's text (not a normal cap)

# Portal URL the CLI/local-UI push & pull to
# EPISTEMIC_PORTAL=http://localhost:8810

# Protect whole-KB replacement and moderation on the portal. Source-by-source contributions
# remain keyless. Set ADMIN_TOKEN on the server and the same value locally for CLI/UI pushes.
# ADMIN_TOKEN=replace-with-a-long-random-value
# EPISTEMIC_ADMIN_TOKEN=replace-with-the-server-admin-token

# Contact email -> OpenAlex/Crossref "polite pool" (faster, higher limits)
# EPISTEMIC_CONTACT_EMAIL=you@example.org

# Hosted fetch safety limits. Defaults are usually fine.
# EPISTEMIC_MAX_BODY_BYTES=4194304
# EPISTEMIC_MAX_FETCH_BYTES=12582912
# EPISTEMIC_MAX_FETCH_URLS=25

# Optional: higher Semantic Scholar rate limits
# SEMANTIC_SCHOLAR_API_KEY=
