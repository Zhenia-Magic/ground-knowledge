# Copy to .env and fill in. Loaded automatically by cli.py, the local UI, and the portal.
# Real shell env vars always take precedence over these.

# LLM key — only needed for AUTOMATIC labelling (discovery + fetch work with no key).
# Set ONE of these. Anthropic is checked first (needed for web search / deep research), then
# NVIDIA, then the rest in this order — every non-Anthropic provider labels fetched text fine.
ANTHROPIC_API_KEY=
# NVIDIA_API_KEY=      # free, rate-limited (~40 req/min) — build.nvidia.com
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# Optional: pin the model (overrides the per-provider default — e.g. deepseek-chat,
# deepseek-reasoner, gpt-4o, mistral-large-latest, claude-sonnet-4-6, gemini-2.0-flash, or any
# build.nvidia.com model: z-ai/glm-5.2, minimaxai/minimax-m3, nvidia/nemotron-3-ultra-550b-a55b,
# deepseek-ai/deepseek-v4-pro, deepseek-ai/deepseek-v4-flash).
# EPISTEMIC_MODEL=

# Portal URL the CLI/local-UI push & pull to
# EPISTEMIC_PORTAL=http://localhost:8810

# Protect whole-KB replacement and moderation on the portal. Source-by-source contributions
# remain keyless. Set ADMIN_TOKEN on the server and the same value locally for CLI/UI pushes.
# ADMIN_TOKEN=replace-with-a-long-random-value
# EPISTEMIC_ADMIN_TOKEN=replace-with-the-server-admin-token

# Contact email -> OpenAlex/Crossref "polite pool" (faster, higher limits)
# EPISTEMIC_CONTACT_EMAIL=you@example.org

# Hosted fetch safety limits. Defaults are usually fine.
# EPISTEMIC_MAX_BODY_BYTES=4194304
# EPISTEMIC_MAX_FETCH_BYTES=12582912
# EPISTEMIC_MAX_FETCH_URLS=25

# Optional: higher Semantic Scholar rate limits
# SEMANTIC_SCHOLAR_API_KEY=
